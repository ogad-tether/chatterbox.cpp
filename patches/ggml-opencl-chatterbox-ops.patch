diff --git a/src/ggml-opencl/kernels/mish.cl b/src/ggml-opencl/kernels/mish.cl
new file mode 100644
index 00000000..a1ebf57f
--- /dev/null
+++ b/src/ggml-opencl/kernels/mish.cl
@@ -0,0 +1,35 @@
+#pragma OPENCL EXTENSION cl_khr_fp16 : enable
+
+static inline float mish_f32(float x) {
+    const float sp = (x > 20.0f) ? x : log(1.0f + exp(x));
+    return x * tanh(sp);
+}
+
+static inline float4 mish_f32_4(float4 x) {
+    const float4 sp = (x > (float4)(20.0f)) ? x : log((float4)(1.0f) + exp(x));
+    return x * tanh(sp);
+}
+
+kernel void kernel_mish_f32(
+        global const float * src0,
+        ulong                offset0,
+        global       float * dst,
+        ulong                offsetd
+) {
+    src0 = (global float*)((global char*)src0 + offset0);
+    dst  = (global float*)((global char*)dst + offsetd);
+
+    dst[get_global_id(0)] = mish_f32(src0[get_global_id(0)]);
+}
+
+kernel void kernel_mish_f32_4(
+        global const float4 * src0,
+        ulong                 offset0,
+        global       float4 * dst,
+        ulong                 offsetd
+) {
+    src0 = (global float4*)((global char*)src0 + offset0);
+    dst  = (global float4*)((global char*)dst + offsetd);
+
+    dst[get_global_id(0)] = mish_f32_4(src0[get_global_id(0)]);
+}
